{
  "custom/yt-music-play-pause": {
    "format": "{}",  // will be filled by script output
    "return-type": "json",
    "tooltip": false,
    "interval": 3,
    "exec": "~/.config/waybar/scripts/yt-music-playpause-toggle.sh",
    "on-click": "~/.config/waybar/scripts/yt-music-cmd.sh play-pause"
  }
}
