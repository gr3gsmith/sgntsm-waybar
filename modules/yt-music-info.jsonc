{
  "custom/yt-music-info": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/yt-music-info.sh",
    "interval": 3,
    "return-type": "json",
    "on-click": "~/.config/waybar/scripts/yt-music-cmd.sh play-pause",
    "on-click-right": "~/.config/waybar/scripts/yt-music-cmd.sh next",
    "on-click-middle": "~/.config/waybar/scripts/yt-music-cmd.sh previous",
    "tooltip": true
  }
}
